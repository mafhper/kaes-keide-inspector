{
  "manifest_version": 3,
  "name": "Kaes Keid Inspector",
  "version": "1.0.0",
  "description": "Smart CSS/HTML inspector. Explore design properties, colors, typography, contrast and assets from any website.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Kaes Keid Inspector",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.ts"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "detect-globals.js",
        "assets/*",
        "icons/*",
        "logo.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
